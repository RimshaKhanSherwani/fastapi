# Supabase project credentials (Project Settings -> API in the Supabase dashboard).
# The frontend reads these at build/runtime via Vite. When deploying to Vercel,
# set the same two variables in the project's Environment Variables.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
